# ---------------------------------------------------------------------------
# Root example env. Copy the relevant blocks into backend/.env and frontend/.env
# (or export them in your shell) before running. Nothing here is hard-coded in
# source — every value below has a documented default in the app's config layer.
# ---------------------------------------------------------------------------

# ---- Backend (backend/.env) ----
# Host/interface the API binds to.
HOST=127.0.0.1
# Port the API listens on.
PORT=8787
# Path to the SQLite file. Relative paths resolve from the backend package root.
DATABASE_PATH=./data/spinner.db
# Comma-separated list of allowed CORS origins (the frontend URL). Use * to allow any.
CORS_ORIGIN=http://localhost:5173

# ---- Frontend (frontend/.env) ----
# Base URL the browser uses to reach the backend API. Must be reachable from the client.
VITE_API_URL=http://localhost:8787
# Dev server host/port for Vite.
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173
