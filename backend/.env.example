# Backend configuration. Copy to backend/.env to override. All values are optional;
# the defaults shown here match src/config.ts.
HOST=127.0.0.1
PORT=8787
DATABASE_PATH=./data/spinner.db
# Allowed CORS origin = the frontend URL. Comma-separate for multiple, or use * for any.
# You only need ONE loopback variant: localhost and 127.0.0.1 twins are added
# automatically, so just match your frontend's port here.
CORS_ORIGIN=http://localhost:5173
