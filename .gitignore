# ---- Dependencies -------------------------------------------------------
node_modules/
.pnp/
.pnp.js

# ---- Build output -------------------------------------------------------
# Unanchored, so these match at any depth (backend/dist, frontend/dist, …).
dist/
build/
*.tsbuildinfo
# Vite cache
.vite/

# ---- Runtime data (local SQLite lives in backend/data) ------------------
data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ---- Environment --------------------------------------------------------
# Ignore all env files EXCEPT the committed *.example templates.
.env
.env.*
!.env.example
!**/.env.example

# ---- Logs ---------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ---- Editor / OS --------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
# Keep sharable workspace recommendations if the team adds them.
!.vscode/extensions.json

# ---- Test / coverage (future-proofing) ----------------------------------
coverage/
.nyc_output/
